<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Diet Coke — Pour Experience</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{--red:#E41E2B;--dark:#0a0a0a;}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--dark);font-family:'DM Sans',sans-serif;overflow:hidden;height:100vh;width:100vw;cursor:none;}
#cursor{position:fixed;width:12px;height:12px;background:var(--red);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .2s,height .2s,background .2s;}
#cursor-ring{position:fixed;width:36px;height:36px;border:1px solid rgba(228,30,43,.5);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .25s,height .25s;}
#bg{position:fixed;inset:0;background:linear-gradient(rgba(228,30,43,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(228,30,43,.025) 1px,transparent 1px);background-size:60px 60px;z-index:0;}
#bg::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 50%,transparent 20%,#0a0a0a 100%);}
#scanlines{position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.1) 2px,rgba(0,0,0,.1) 4px);pointer-events:none;z-index:999;opacity:.4;}
#scene{position:fixed;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:1;}
.top-bar{position:fixed;top:0;left:0;right:0;display:flex;justify-content:space-between;align-items:center;padding:24px 48px;z-index:10;}
.logo{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:rgba(255,255,255,.3);letter-spacing:4px;}
.status-dot{display:flex;align-items:center;gap:8px;font-size:.7rem;color:rgba(255,255,255,.2);letter-spacing:2px;text-transform:uppercase;}
.dot{width:6px;height:6px;border-radius:50%;background:#00ff88;animation:blink 2s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
#canWrap{position:relative;display:flex;flex-direction:column;align-items:center;cursor:none;user-select:none;}
#canContainer{position:relative;width:200px;height:340px;transform-origin:50% 50%;transition:transform .4s cubic-bezier(.25,.46,.45,.94);filter:drop-shadow(0 40px 70px rgba(0,0,0,.9)) drop-shadow(0 0 50px rgba(228,30,43,.18));will-change:transform;}
#canWrap:hover #canContainer{transform:translateY(-10px) scale(1.04);filter:drop-shadow(0 50px 90px rgba(0,0,0,.95)) drop-shadow(0 0 80px rgba(228,30,43,.35));}
.tipping{transform:rotate(88deg) translate(42px,82px) scale(1.04) !important;transition:transform 1.1s cubic-bezier(.45,0,.1,1) !important;}
.empty{transform:rotate(88deg) translate(42px,82px) scale(1.04) !important;}
#hint{margin-top:28px;display:flex;flex-direction:column;align-items:center;gap:10px;animation:floatHint 3s ease-in-out infinite;transition:opacity .5s;}
@keyframes floatHint{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
.hint-text{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:5px;color:rgba(228,30,43,.7);}
.hint-arrow{width:1px;height:30px;background:linear-gradient(to bottom,rgba(228,30,43,.7),transparent);animation:arrowPulse 1.5s ease-in-out infinite;}
@keyframes arrowPulse{0%,100%{opacity:1;height:30px}50%{opacity:.4;height:20px}}
#spillCanvas{position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:3;filter:url(#metaball);}
#fizzCanvas{position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:4;}
#glowCanvas{position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:2;}
#svgFilters{position:fixed;width:0;height:0;pointer-events:none;}
.bottom-bar{position:fixed;bottom:0;left:0;right:0;display:flex;justify-content:space-between;padding:24px 48px;z-index:10;}
.stat{display:flex;flex-direction:column;gap:4px;}
.stat-label{font-size:.6rem;letter-spacing:3px;color:rgba(255,255,255,.15);text-transform:uppercase;}
.stat-value{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:rgba(255,255,255,.35);letter-spacing:2px;}
#volumeVal{color:var(--red);transition:color .5s;}
#flash{position:fixed;inset:0;background:white;opacity:0;pointer-events:none;z-index:500;transition:opacity .05s;}
.pool-ripple{position:fixed;border-radius:50%;border:1px solid rgba(228,30,43,.4);pointer-events:none;z-index:5;animation:rippleOut 1.5s ease-out forwards;}
@keyframes rippleOut{0%{transform:scale(.3);opacity:.8}100%{transform:scale(1);opacity:0}}
#pourText{position:fixed;bottom:80px;left:50%;transform:translateX(-50%);font-family:'Bebas Neue',sans-serif;font-size:3rem;letter-spacing:12px;color:var(--red);opacity:0;z-index:10;pointer-events:none;text-shadow:0 0 30px rgba(228,30,43,.5);transition:opacity .5s;}
.title-wrap{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:0;opacity:.025;}
.title-big{font-family:'Bebas Neue',sans-serif;font-size:22vw;color:white;line-height:.9;white-space:nowrap;}
</style>
</head>
<body>

<div id="bg"></div>
<div id="scanlines"></div>
<div class="title-wrap"><div class="title-big">COKE</div></div>

<svg id="svgFilters">
