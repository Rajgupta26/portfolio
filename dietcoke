          text-anchor="middle"
          font-family="Arial,sans-serif"
          font-size="5.8" font-weight="400"
          fill="rgba(70,70,70,0.75)" letter-spacing="1"
          clip-path="url(#clipBody)">355 mL  12 FL OZ</text>

        <!-- Barcode -->
