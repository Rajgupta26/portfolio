      <!-- invisible hole marker for physics emission point -->
      <div id="canHoleMarker" style="position:absolute;top:8px;left:50%;transform:translateX(-50%);width:28px;height:9px;opacity:0;pointer-events:none;"></div>
    </div>

    <div id="hint">
      <div class="hint-text">Click to Open</div>
      <div class="hint-arrow"></div>
    </div>
  </div>
</div>

<div class="bottom-bar">
  <div class="stat"><div class="stat-label">Particles</div><div class="stat-value" id="particleCount">0</div></div>
  <div class="stat" style="text-align:center"><div class="stat-label">Volume Remaining</div><div class="stat-value" id="volumeVal">355 mL</div></div>
  <div class="stat" style="text-align:right"><div class="stat-label">Temperature</div><div class="stat-value">4°C</div></div>
</div>

<div id="cursor"></div>
<div id="cursor-ring"></div>

<script>
const cursor=document.getElementById('cursor');
const cursorRing=document.getElementById('cursor-ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cursor.style.left=mx+'px';cursor.style.top=my+'px';});
(function ringLoop(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;cursorRing.style.left=rx+'px';cursorRing.style.top=ry+'px';requestAnimationFrame(ringLoop);})();
document.addEventListener('mousedown',()=>{cursor.style.width='8px';cursor.style.height='8px';});
document.addEventListener('mouseup',()=>{cursor.style.width='12px';cursor.style.height='12px';});

const spillCanvas=document.getElementById('spillCanvas');
const sCtx=spillCanvas.getContext('2d');
const fizzCanvas=document.getElementById('fizzCanvas');
const fCtx=fizzCanvas.getContext('2d');
const glowCanvas=document.getElementById('glowCanvas');
const gCtx=glowCanvas.getContext('2d');
let W,H;
function resize(){W=spillCanvas.width=fizzCanvas.width=glowCanvas.width=window.innerWidth;H=spillCanvas.height=fizzCanvas.height=glowCanvas.height=window.innerHeight;}
window.addEventListener('resize',resize);resize();

const GRAVITY=0.55,DAMPING=0.38,FRICTION=0.78,REST_DENS=0.006,PRESSURE_MULT=0.04,VISCOSITY=0.3,NEIGHBOR_DIST=55;
let particles=[],fizzParticles=[],state='idle',volumeLeft=355,frameCount=0;
let glowX=0,glowY=0,glowR=0,glowAlpha=0;

class FluidParticle{
  constructor(x,y,vx,vy){
    this.x=x;this.y=y;this.vx=vx;this.vy=vy;
    this.r=9+Math.random()*5;this.mass=.7+Math.random()*.6;
    this.pooled=false;this.age=0;this.pressure=0;
    const l=16+Math.floor(Math.random()*14);
    this.color=`rgb(${l},${Math.floor(l*.3)},0)`;
  }
  computePressure(others){
    let d=0;
    for(const o of others){if(o===this)continue;const dx=this.x-o.x,dy=this.y-o.y,d2=dx*dx+dy*dy;if(d2<NEIGHBOR_DIST*NEIGHBOR_DIST){const w=1-Math.sqrt(d2)/NEIGHBOR_DIST;d+=w*w*o.mass;}}
    this.pressure=PRESSURE_MULT*(d-REST_DENS*this.r*this.r);
  }
  applyPressure(others){
    let fx=0,fy=0;
    for(const o of others){if(o===this)continue;const dx=this.x-o.x,dy=this.y-o.y,dist=Math.sqrt(dx*dx+dy*dy);if(dist<NEIGHBOR_DIST&&dist>.01){const w=1-dist/NEIGHBOR_DIST,pF=w*(this.pressure+o.pressure)*.5;fx+=(dx/dist)*pF;fy+=(dy/dist)*pF;fx+=(o.vx-this.vx)*w*VISCOSITY*.05;fy+=(o.vy-this.vy)*w*VISCOSITY*.05;}}
    this.vx+=fx/this.mass;this.vy+=fy/this.mass;
  }
  update(){
    this.age++;
    if(!this.pooled){
      this.vy+=GRAVITY*this.mass;this.vx*=.995;this.vy*=.998;
      this.x+=this.vx;this.y+=this.vy;
      if(this.x<this.r){this.x=this.r;this.vx=Math.abs(this.vx)*DAMPING;}
      if(this.x>W-this.r){this.x=W-this.r;this.vx=-Math.abs(this.vx)*DAMPING;}
      if(this.y>=H-this.r-2){this.y=H-this.r-2;this.vy=-Math.abs(this.vy)*DAMPING;this.vx*=FRICTION;if(Math.abs(this.vy)<1.5&&Math.abs(this.vx)<1.5){this.pooled=true;this.vx=(Math.random()-.5)*2.5;this.vy=0;}}
    }else{
      this.x+=this.vx;this.vx*=.88;
      if(this.r<22)this.r+=.08;
      this.y=H-this.r-2;
    }
  }
  draw(ctx){ctx.beginPath();ctx.arc(this.x,this.y,this.r,0,Math.PI*2);ctx.fillStyle=this.color;ctx.fill();}
}

class FizzParticle{
  constructor(x,y,vx,vy,col,type){this.x=x;this.y=y;this.vx=vx;this.vy=vy;this.r=type==='bubble'?1+Math.random()*2:1.5+Math.random()*3;this.col=col;this.life=1;this.decay=type==='bubble'?.015:type==='mist'?.012:.025;this.type=type;}
  update(){
    if(this.type==='bubble'){this.vy-=.15;this.vx+=(Math.random()-.5)*.3;}else{this.vy+=.35;}
    this.x+=this.vx;this.y+=this.vy;this.vx*=.97;this.vy*=.97;this.life-=this.decay;
    if(this.y>H){this.y=H;this.vy*=-.2;}
  }
  draw(ctx){
    const a=Math.max(0,this.life);
    ctx.beginPath();ctx.globalAlpha=a;ctx.arc(this.x,this.y,this.r,0,Math.PI*2);
    ctx.fillStyle=this.type==='mist'?`rgba(220,210,195,${a*.5})`:this.col;ctx.fill();
    if(this.type==='bubble'){ctx.strokeStyle=`rgba(255,255,255,${a*.6})`;ctx.lineWidth=.5;ctx.stroke();}
    ctx.globalAlpha=1;
  }
}

function drawGlow(){
  gCtx.clearRect(0,0,W,H);
  if(glowAlpha>.01){
    const g=gCtx.createRadialGradient(glowX,glowY,0,glowX,glowY,glowR);
    g.addColorStop(0,`rgba(228,30,43,${glowAlpha*.15})`);
    g.addColorStop(.4,`rgba(180,20,20,${glowAlpha*.08})`);
    g.addColorStop(1,'rgba(228,30,43,0)');
    gCtx.fillStyle=g;gCtx.fillRect(0,0,W,H);glowAlpha*=.995;
  }
  if(particles.some(p=>p.pooled)){
    const pg=gCtx.createLinearGradient(0,H-120,0,H);
    pg.addColorStop(0,'rgba(228,30,43,0)');
    pg.addColorStop(1,'rgba(40,10,0,0.6)');
    gCtx.fillStyle=pg;gCtx.fillRect(0,H-120,W,120);
  }
}

function getEmit(){
  const marker=document.getElementById('canHoleMarker');
  const canEl=document.getElementById('canContainer');
  const mr=marker.getBoundingClientRect();
  const cr=canEl.getBoundingClientRect();
  const hx=mr.left+mr.width/2,hy=mr.top+mr.height/2;
  const cx=cr.left+cr.width/2,cy=cr.top+cr.height/2;
  return{x:hx,y:hy,angle:Math.atan2(hy-cy,hx-cx)};
}

function animate(){
  frameCount++;
  sCtx.clearRect(0,0,W,H);fCtx.clearRect(0,0,W,H);drawGlow();
  const e=getEmit();
  if(state==='opening'){
    for(let i=0;i<8;i++){
      fizzParticles.push(new FizzParticle(e.x+(Math.random()-.5)*10,e.y,(Math.random()-.5)*8,-Math.random()*14-6,'rgba(255,255,255,.9)','splash'));
      fizzParticles.push(new FizzParticle(e.x+(Math.random()-.5)*8,e.y+(Math.random()-.5)*8,(Math.random()-.5)*5,-Math.random()*10-3,'rgba(255,255,255,.7)','bubble'));
    }
    glowX=e.x;glowY=e.y;glowR=200;glowAlpha=1.5;state='waitspill';
  }
  if(state==='spilling'&&volumeLeft>0){
    for(let i=0;i<9;i++){
      const a=e.angle+(Math.random()-.5)*.18,sp=12+Math.random()*8;
      const sx=e.x+(Math.random()-.5)*8,sy=e.y+(Math.random()-.5)*6;
      particles.push(new FluidParticle(sx,sy,Math.cos(a)*sp,Math.sin(a)*sp));
      if(Math.random()>.6)fizzParticles.push(new FizzParticle(sx,sy,Math.cos(a)*sp*1.4+(Math.random()-.5)*4,Math.sin(a)*sp*1.4+(Math.random()-.5)*4,'rgba(230,215,195,.7)','mist'));
      if(Math.random()>.75)fizzParticles.push(new FizzParticle(sx+(Math.random()-.5)*20,sy+(Math.random()-.5)*20,(Math.random()-.5)*1.5,-Math.random()*3-1,'rgba(255,255,255,.5)','bubble'));
    }
    glowX=e.x;glowY=e.y;glowR=350;glowAlpha=Math.min(glowAlpha+.05,1.8);
    volumeLeft-=.15;if(volumeLeft<0)volumeLeft=0;
    const ml=Math.round(volumeLeft);
    document.getElementById('volumeVal').textContent=ml+' mL';
    if(ml<50)document.getElementById('volumeVal').style.color='#ff6b6b';
  }
  const active=particles.filter(p=>!p.pooled);
  if(frameCount%3===0&&active.length<300){for(const p of active)p.computePressure(active);for(const p of active)p.applyPressure(active);}
  for(let i=particles.length-1;i>=0;i--){const p=particles[i];p.update();p.draw(sCtx);if(particles.length>1800&&p.pooled&&Math.random()>.994)particles.splice(i,1);}
  for(let i=fizzParticles.length-1;i>=0;i--){const p=fizzParticles[i];p.update();p.draw(fCtx);if(p.life<=0)fizzParticles.splice(i,1);}
  if(frameCount%60===0&&particles.some(p=>p.pooled)){
    const px=W/2+(Math.random()-.5)*200;
    const rip=document.createElement('div');rip.className='pool-ripple';
    rip.style.cssText=`left:${px-40}px;top:${H-80}px;width:80px;height:30px;`;
    document.body.appendChild(rip);setTimeout(()=>rip.remove(),1500);
  }
  if(frameCount%10===0)document.getElementById('particleCount').textContent=particles.length;
  requestAnimationFrame(animate);
}

document.getElementById('canWrap').addEventListener('click',()=>{
  if(state!=='idle')return;
  document.getElementById('hint').style.opacity='0';
  setTimeout(()=>document.getElementById('hint').style.display='none',500);
  const flash=document.getElementById('flash');
  flash.style.opacity='.7';setTimeout(()=>flash.style.opacity='0',80);
  document.getElementById('openHole').setAttribute('opacity','1');
  state='opening';
  const e=getEmit();
  for(let i=0;i<30;i++){
    const angle=Math.random()*Math.PI*2,spd=Math.random()*15+5;
    fizzParticles.push(new FizzParticle(e.x,e.y,Math.cos(angle)*spd,Math.sin(angle)*spd,'rgba(255,255,255,.9)','splash'));
  }
  const cc=document.getElementById('canContainer');
  let v=0;
  const vib=setInterval(()=>{
    const rx=(Math.random()-.5)*12,ry=(Math.random()-.5)*12;
    cc.style.transform=`scale(1.03) translateY(-8px) translate(${rx}px,${ry}px)`;
    if(++v>=8){clearInterval(vib);cc.style.transform='';}
  },40);
  setTimeout(()=>{
    cc.classList.add('tipping');state='waitspill';
    setTimeout(()=>{
      state='spilling';
      document.getElementById('pourText').style.opacity='1';
      const chk=setInterval(()=>{
        if(volumeLeft<=0){state='empty';cc.classList.remove('tipping');cc.classList.add('empty');document.getElementById('pourText').textContent='EMPTY';clearInterval(chk);}
      },500);
    },600);
  },380);
});

document.getElementById('canWrap').addEventListener('mouseenter',()=>{cursor.style.width='20px';cursor.style.height='20px';cursor.style.background='rgba(228,30,43,.7)';cursorRing.style.width='60px';cursorRing.style.height='60px';});
document.getElementById('canWrap').addEventListener('mouseleave',()=>{cursor.style.width='12px';cursor.style.height='12px';cursor.style.background='var(--red)';cursorRing.style.width='36px';cursorRing.style.height='36px';});

animate();
</script>
</body>
</html>
